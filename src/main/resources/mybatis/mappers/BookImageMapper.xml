<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.team01.book.dao.BookImageDao">

        <insert id="insertBookImages" parameterType="BookImageVO">
            INSERT INTO bookImage
                (bookId, imagePath, isMain)
            VALUES
                (
                 #{bookId},
                 #{imagePath},
                 #{isMain}
                )
        </insert>

        <select id="selectImages" resultType="String">
            select
                bookId,
                imagePath
            from bookImage
            where bookId IN
            <foreach item="item" collection="list" open="(" separator="," close=")">
                #{item}
            </foreach>
        </select>



</mapper>
